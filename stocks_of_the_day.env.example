# Stocks of the Day configuration
# Copy these values into a local .env file in the same directory where you run the script.

# Required for Korean company profiles and DART financial verification where available.
DART_API_KEY=

# Required for US company news.
NEWSAPI_KEY=

# Required for Korean company news.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Optional. Used for US analyst estimates where available; yfinance is used as fallback/source for valuation data.
FMP_API_KEY=

# Claude-powered news brief (Recent Developments section).
# If ANTHROPIC_API_KEY is empty the section degrades gracefully and the pipeline still runs.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Gmail SMTP delivery.
# Use a Gmail app password, not your normal Gmail password.
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient1@example.com,recipient2@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Runtime controls.
DRY_RUN=true
OUTPUT_HTML_PATH=stocks_of_the_day_email_preview.html
SMA_WINDOW=30
LOOKBACK_DAYS=140
PICKS_PER_MARKET=3
HEALTH_CANDIDATE_LIMIT=20
REQUEST_TIMEOUT=20
RETRY_COUNT=3
RETRY_SLEEP_SECONDS=2.0

# Minimum delay between consecutive DART API calls (rate-limit protection).
DART_CALL_DELAY_SECONDS=0.7

# SEC EDGAR (primary source for US quarterly financials). SEC's fair-access
# policy requires a real identifying contact in the User-Agent header; if
# SEC_CONTACT_EMAIL is empty, SEC EDGAR is skipped and yfinance is used.
SEC_CONTACT_NAME=Your Name
SEC_CONTACT_EMAIL=your_email@example.com

# Exclude KRX preferred shares (e.g. 005935, names ending 우/우B/2우B) from screening.
EXCLUDE_PREFERRED_SHARES=true

# Test email loop. When TEST_RUN=true, DRY_RUN is disabled, EMAIL_TO is ignored,
# and the report is sent to TEST_EMAIL_TO after each run, then repeated every minute.
TEST_RUN=false
TEST_EMAIL_TO=juhanchang0606@gmail.com
TEST_INTERVAL_SECONDS=60

# Scheduler. With SCHEDULE_INTERVAL_MINUTES=0 the script runs daily at
# SCHEDULE_TIME_KST (Asia/Seoul); otherwise it runs every N minutes.
SCHEDULER_ENABLED=false
SCHEDULE_INTERVAL_MINUTES=0
SCHEDULE_TIME_KST=07:00

# Pick history database used by the "Previous Picks Review" email section.
PICKS_DB_PATH=picks.db
